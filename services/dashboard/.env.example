# ECO-130: base URLs for the real backends this dashboard talks to.
# Both have sensible localhost defaults in src/lib/api-client.ts (matching
# `make api`'s default port), so this file is only needed to point at a
# non-default deployment.

# services/forecast-api (FastAPI, port 8003 via `make api`)
NEXT_PUBLIC_FORECAST_API_BASE=http://localhost:8003

# services/data-pipeline's warehouse API (FastAPI, port 8002)
NEXT_PUBLIC_WAREHOUSE_API_BASE=http://localhost:8002
